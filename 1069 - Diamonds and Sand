#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);
    for(int i = 0; i < n; i++){
        char a[1001];
        scanf("%s", a);
       int sum = 0;
        int sum1 = 0;
        for(int i = 0; a[i] != '\0'; i++){
            if(a[i] == '<'){
                sum++;
            }
            else if(a[i] == '>' && sum > 0){
                sum--;
                sum1++;
            }
        }
        printf("%d\n", sum1);
    }

    return 0;
}
