
//1065 - Even Between five Numbers
#include <stdio.h>

int main() {
    int a[5];
    int sum = 0;
    for(int i = 0; i < 5; i++){
    scanf("%d", &a[i]);
    }
    for(int i = 0; i < 5; i++){
        if(a[i] % 2 == 0){
            sum ++;
        }
    }
  printf("%d valores pares\n", sum);
    return 0;
}
